# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit real credentials
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Vault — sensitive data directories (never commit)
/vault/secrets/
/vault/temp/
/vault/logs/
/vault/backups/
/vault/exports/
/vault/audit/
# Vault config and reports are intentionally tracked (no secrets inside)
# /vault/config/ — OK to commit (no credentials)
# /vault/reports/ — OK to commit (PDFs/HTML)

# Runtime / local data
/.data/
dev-server.log
*.log

# Workspace files
*.code-workspace

# Playwright / test artifacts
test-results/
playwright-report/

# OS
Thumbs.db

.vercel
.env*
ENVS.md
