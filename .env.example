# ═══════════════════════════════════════════════════════════════
# LEONARDO CS COCKPIT — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ═══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Leonardo CS Cockpit

# ── Supabase (Database + Auth) ────────────────────────────────────────────────
# https://supabase.com/dashboard/project/<project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Zabbix Monitoring ─────────────────────────────────────────────────────────
# JSON-RPC API — requires Zabbix 5.4+
ZABBIX_API_URL=https://your-zabbix-instance/api_jsonrpc.php
ZABBIX_USER=
ZABBIX_PASS=
NEXT_PUBLIC_ZABBIX_URL=https://your-zabbix-instance
# Set to 0 if Zabbix uses self-signed certificate
NODE_TLS_REJECT_UNAUTHORIZED=1

# ── GLPI (Help Desk / ITSM) ───────────────────────────────────────────────────
# API Tokens: GLPI > Configurações > Geral > API
GLPI_URL=https://your-glpi-instance/apirest.php
GLPI_APP_TOKEN=
GLPI_USER_TOKEN=
NEXT_PUBLIC_GLPI_URL=https://your-glpi-instance

# ── Jira (Project Management) ─────────────────────────────────────────────────
# Token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# ── HubSpot CRM ───────────────────────────────────────────────────────────────
# OAuth App: https://developers.hubspot.com/
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:3000/api/hubspot/auth/callback
HUBSPOT_API_KEY=
HUBSPOT_ENCRYPTION_KEY=

# ── Datadog Observability ─────────────────────────────────────────────────────
# API Key: https://app.datadoghq.com/organization-settings/api-keys
# App Key: https://app.datadoghq.com/organization-settings/application-keys
DD_API_KEY=
DD_APP_KEY=
# Site options: datadoghq.com | datadoghq.eu | us3.datadoghq.com
DD_SITE=datadoghq.com

# ── Microsoft 365 / Graph API ─────────────────────────────────────────────────
# Azure Portal > App Registrations > New Registration
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# ── SMTP (Email — Office 365) ─────────────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
NOTIFICATION_EMAIL_TO=

# ── Resend (Modern Email API) ─────────────────────────────────────────────────
# Alternative to SMTP: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── WhatsApp Business Cloud API ───────────────────────────────────────────────
# https://developers.facebook.com/apps/
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ── N8N Automation ────────────────────────────────────────────────────────────
N8N_URL=http://localhost:5678
N8N_WEBHOOK_URL=

# ── Notifications ─────────────────────────────────────────────────────────────
TEAMS_WEBHOOK_URL=

# ── OpenAI (AI Analysis) ──────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Vault Security ────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=
